.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #FFF8E7;
}

.section {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 179, 71, 0.1);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.category-list {
  max-height: 500rpx;
  margin-bottom: 20rpx;
}

.category-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.category-item:last-child {
  border-bottom: none;
}

.category-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.category-info .icon {
  font-size: 48rpx;
}

.category-info .name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.actions {
  display: flex;
  gap: 16rpx;
}

.edit-btn,
.delete-btn {
  padding: 12rpx 28rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  border: none;
}

.edit-btn {
  background-color: #FFF8E7;
  color: #FF9800;
}

.delete-btn {
  background-color: #fef2f2;
  color: #e74c3c;
}

.empty-state {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

.add-category-btn {
  background: linear-gradient(135deg, #FFB347 0%, #FF9800 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  padding: 24rpx;
  border-radius: 50rpx;
  box-shadow: 0 8rpx 30rpx rgba(255, 179, 71, 0.4);
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 80%;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 30rpx;
}

.form-group {
  margin-bottom: 30rpx;
}

.form-input {
  width: 100%;
  padding: 24rpx;
  background-color: #FFF8E7;
  border-radius: 16rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.icon-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.icon-option {
  width: 90rpx;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #FFF8E7;
  border-radius: 16rpx;
  font-size: 48rpx;
  border: 4rpx solid transparent;
  transition: all 0.3s ease;
}

.icon-option.active {
  background-color: #FFE4B5;
  border-color: #FF9800;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
}

.cancel-btn,
.confirm-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.cancel-btn {
  background-color: #f5f5f5;
  color: #666;
}

.confirm-btn {
  background: linear-gradient(135deg, #FFB347 0%, #FF9800 100%);
  color: #fff;
  box-shadow: 0 8rpx 30rpx rgba(255, 179, 71, 0.4);
}