<view class="container" data-theme="{{theme}}">
  <view class="type-switch">
    <view class="type-btn {{type === 'expense' ? 'active' : ''}}" bindtap="switchType" data-type="expense">支出</view>
    <view class="type-btn {{type === 'income' ? 'active' : ''}}" bindtap="switchType" data-type="income">收入</view>
  </view>
  
  <view class="amount-input">
    <input type="digit" placeholder="0.00" value="{{amount}}" bindinput="onAmountInput" />
    <view class="voice-btn-wrap">
      <view class="voice-btn {{voiceStatus === 'recording' ? 'recording' : ''}}" 
            bindtouchstart="onVoiceStart" 
            bindtouchend="onVoiceEnd"
            bindtouchcancel="onVoiceCancel">
        <view class="voice-icon">🎤</view>
        <view class="voice-text">{{voiceStatus === 'recording' ? '松开识别' : (voiceStatus === 'processing' ? '识别中...' : '按住说话')}}</view>
      </view>
    </view>
  </view>

  <!-- 语音识别结果预览 -->
  <view class="voice-result" wx:if="{{voiceResult.text}}">
    <view class="voice-result-text">识别：{{voiceResult.text}}</view>
    <view class="voice-result-tip" wx:if="{{voiceResult.parsed}}">
      已自动填入 ✅ 请检查下方信息是否准确
    </view>
  </view>
  
  <view class="quick-amount">
    <view class="quick-btn" wx:for="{{quickAmounts}}" wx:key="*this" bindtap="setQuickAmount" data-amount="{{item}}">{{item}}</view>
  </view>

  <view class="template-section" wx:if="{{templates.length > 0}}">
    <view class="template-title">常用模板</view>
    <scroll-view scroll-x class="template-scroll">
      <view class="template-item" wx:for="{{templates}}" wx:key="id" bindtap="useTemplate" data-id="{{item.id}}">
        <text>{{item.name}}</text>
      </view>
      <view class="template-item add-template" bindtap="saveAsTemplate">
        <text>+ 保存模板</text>
      </view>
    </scroll-view>
  </view>
  
  <view class="form-item">
    <view class="label">分类</view>
    <view class="category-grid">
      <view class="category-item {{category === item.name ? 'active' : ''}}" wx:for="{{filteredCategories}}" wx:key="name" bindtap="selectCategory" data-name="{{item.name}}">
        <view class="category-icon">{{item.icon || '📦'}}</view>
        <view class="category-name">{{item.name}}</view>
      </view>
    </view>
  </view>
  
  <view class="form-item">
    <view class="label">账户</view>
    <view class="account-scroll">
      <view class="account-item {{account === item.name ? 'active' : ''}}" wx:for="{{accounts}}" wx:key="name" bindtap="selectAccount" data-name="{{item.name}}">
        <view class="account-name">{{item.name}}</view>
      </view>
      <view class="account-item {{account === '其他' ? 'active' : ''}} account-other" bindtap="selectOtherAccount">
        <view class="account-name">其他</view>
      </view>
    </view>
    <view class="custom-account-input" wx:if="{{showCustomAccountInput}}">
      <input type="text" placeholder="请输入自定义账户名称" value="{{customAccountName}}" bindinput="onCustomAccountInput" bindblur="onCustomAccountBlur" focus="{{customAccountFocus}}" />
    </view>
  </view>
  
  <view class="form-item">
    <view class="label">日期</view>
    <picker mode="date" value="{{date}}" bindchange="onDateChange">
      <view class="date-picker">
        <text>{{date}}</text>
        <text class="arrow">></text>
      </view>
    </picker>
  </view>
  
  <view class="form-item">
    <view class="label">备注</view>
    <input type="text" placeholder="请输入备注" value="{{notes}}" bindinput="onNotesInput" />
  </view>

  <view class="action-buttons">
    <button class="delete-btn" wx:if="{{isEdit}}" bindtap="deleteBill">删除账单</button>
    <button class="save-btn" bindtap="saveBill">{{isEdit ? '更新' : '保存'}}</button>
  </view>
</view>