.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: var(--theme-bg);
}

.type-switch {
  display: flex;
  margin-bottom: 30rpx;
  background-color: #fff;
  border-radius: 25rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.type-btn {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  font-size: 32rpx;
  color: #666;
  transition: all 0.3s ease;
}

.type-btn.active {
  background: var(--theme-gradient);
  color: white;
  font-weight: bold;
}

.amount-input {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.amount-prefix {
  font-size: 56rpx;
  font-weight: bold;
  color: #333;
  margin-right: 10rpx;
}

.amount-field {
  flex: 1;
  height: 100rpx;
  font-size: 72rpx;
  text-align: left;
  border: none;
  outline: none;
  color: #333;
  font-weight: bold;
  box-sizing: border-box;
}

/* 小型语音按钮 - 放在金额右侧 */
.voice-btn-small {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  flex-shrink: 0;
  transition: all 0.2s ease;
  box-shadow: 0 4rpx 15rpx rgba(102, 126, 234, 0.4);
}

.voice-btn-small:active {
  transform: scale(0.92);
}

.voice-btn-small.recording {
  background: linear-gradient(135deg, #ff416c 0%, #ff4b2b 100%);
  box-shadow: 0 4rpx 20rpx rgba(255, 65, 108, 0.5);
  animation: recording-pulse 1.5s ease-in-out infinite;
}

.mic-icon {
  font-size: 36rpx;
}

@keyframes recording-pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.08); }
}

/* 语音识别结果 */
.voice-result {
  background: linear-gradient(135deg, #e8f5e9 0%, #f1f8e9 100%);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
  border-left: 6rpx solid #4ECDC4;
}

.voice-result-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.voice-result-tip {
  font-size: 24rpx;
  color: #2E7D32;
  margin-top: 8rpx;
}

.quick-amount {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
  margin-bottom: 25rpx;
}

.quick-btn {
  min-width: 100rpx;
  padding: 20rpx 28rpx;
  background-color: #fff;
  border-radius: 25rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.quick-btn:active {
  transform: scale(0.95);
  background-color: var(--theme-border);
}

.template-section {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.template-title {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 15rpx;
}

.template-scroll {
  white-space: nowrap;
}

.template-item {
  display: inline-block;
  padding: 14rpx 28rpx;
  margin-right: 15rpx;
  background-color: var(--theme-bg);
  border-radius: 25rpx;
  font-size: 26rpx;
  color: #666;
}

.template-item.add-template {
  background-color: var(--theme-border);
  color: var(--theme-secondary);
  font-weight: 600;
}

.form-item {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 18rpx;
  font-weight: 500;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 12rpx;
  border-radius: 16rpx;
  border: 4rpx solid transparent;
  transition: all 0.3s ease;
}

.category-item.active {
  border-color: var(--theme-secondary);
  background-color: var(--theme-bg);
}

.category-icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.category-name {
  font-size: 24rpx;
  color: #333;
  text-align: center;
}

.account-scroll {
  display: flex;
  gap: 15rpx;
  overflow-x: auto;
  padding-bottom: 8rpx;
}

.account-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 28rpx;
  background-color: var(--theme-bg);
  border-radius: 20rpx;
  white-space: nowrap;
  transition: all 0.3s ease;
  min-width: 120rpx;
}

.account-item.active {
  background: var(--theme-gradient);
  font-weight: 600;
}

.account-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.account-name {
  font-size: 24rpx;
  color: #333;
}

.account-item.active .account-name {
  color: white;
}

.date-picker {
  padding: 14rpx 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.date-picker text:first-child {
  font-size: 28rpx;
  color: #333;
}

.arrow {
  font-size: 26rpx;
  color: #999;
}

.form-item input {
  width: 100%;
  padding: 14rpx 0;
  font-size: 28rpx;
  color: #333;
}

.action-buttons {
  margin-top: 35rpx;
  gap: 20rpx;
}

.delete-btn {
  background-color: #fff;
  color: #e74c3c;
  font-size: 30rpx;
  border-radius: 25rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid #e74c3c;
  padding: 24rpx;
}

.save-btn {
  background: var(--theme-gradient);
  color: white;
  font-size: 34rpx;
  font-weight: bold;
  border-radius: 50rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.2);
  border: none;
}

.delete-btn::after,
.save-btn::after {
  border: none;
}

.save-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.account-other {
  border: 2rpx dashed var(--theme-secondary);
  background-color: #fff;
}

.account-other.active {
  background: var(--theme-gradient);
  border-style: solid;
  color: white;
}

.custom-account-input {
  margin-top: 20rpx;
  padding: 20rpx;
  background-color: var(--theme-bg);
  border-radius: 16rpx;
  border: 2rpx solid var(--theme-border);
}

.custom-account-input input {
  width: 100%;
  padding: 12rpx 0;
  font-size: 28rpx;
  color: #333;
  background-color: transparent;
}