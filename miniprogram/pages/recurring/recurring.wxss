.container {
  padding: 30rpx;
  min-height: 100vh;
  background-color: var(--theme-bg);
  padding-bottom: 180rpx;
  box-sizing: border-box;
}

/* 周期账单列表 */
.recurring-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 周期账单卡片 */
.recurring-card {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.recurring-card:active {
  transform: scale(0.98);
}

.recurring-card.disabled {
  opacity: 0.5;
}

/* 卡片主区域 - 左右对称布局 */
.card-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
}

/* 左侧 - 图标和信息 */
.card-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.card-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--theme-bg);
  border-radius: 24rpx;
}

.card-icon {
  font-size: 44rpx;
}

.card-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.card-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.card-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.frequency-tag {
  font-size: 22rpx;
  color: var(--theme-primary);
  background: var(--theme-bg);
  padding: 6rpx 14rpx;
  border-radius: 10rpx;
  font-weight: 500;
}

.card-amount {
  font-size: 30rpx;
  font-weight: bold;
}

.card-amount.expense {
  color: #FF6B6B;
}

.card-amount.income {
  color: #2E7D32;
}

/* 右侧 - 金额和箭头 */
.card-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.next-due {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.due-label {
  font-size: 20rpx;
  color: #999;
}

.due-date {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
}

.expand-icon {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #ccc;
  background: #f8f8f8;
  border-radius: 50%;
  transition: all 0.3s ease;
}

.expand-icon.expanded {
  transform: rotate(180deg);
  background: var(--theme-bg);
  color: var(--theme-primary);
}

/* 展开详情 */
.card-detail {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease;
  background: #fafafa;
}

.card-detail.show {
  max-height: 600rpx;
  border-top: 1rpx solid #f0f0f0;
}

.detail-content {
  padding: 24rpx 32rpx;
}

.detail-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx 32rpx;
}

.detail-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.detail-label {
  font-size: 24rpx;
  color: #999;
  min-width: 56rpx;
}

.detail-value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
}

/* 操作按钮区域 */
.detail-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.toggle-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.toggle-switch {
  width: 88rpx;
  height: 48rpx;
  background: #ddd;
  border-radius: 24rpx;
  padding: 4rpx;
  position: relative;
  transition: background 0.3s ease;
}

.toggle-switch.active {
  background: var(--theme-primary);
}

.switch-dot {
  width: 40rpx;
  height: 40rpx;
  background: #fff;
  border-radius: 50%;
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  transition: transform 0.3s ease;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.15);
}

.toggle-switch.active .switch-dot {
  transform: translateX(40rpx);
}

.switch-label {
  font-size: 24rpx;
  color: #666;
}

.action-btns {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 14rpx 28rpx;
  border-radius: 14rpx;
  font-size: 24rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.95);
}

.action-btn.add {
  background: var(--theme-gradient);
  color: #fff;
  box-shadow: 0 4rpx 12rpx var(--theme-shadow);
}

.action-btn.edit {
  background: var(--theme-bg);
  color: #666;
}

.action-btn.delete {
  background: #FFF0F0;
  color: #FF6B6B;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  text-align: center;
}

/* 添加按钮 */
.add-btn {
  position: fixed;
  bottom: calc(60rpx + env(safe-area-inset-bottom));
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx 60rpx;
  background: var(--theme-gradient);
  border-radius: 50rpx;
  box-shadow: 0 8rpx 30rpx var(--theme-shadow);
  transition: opacity 0.3s ease, transform 0.3s ease;
  z-index: 999;
}

.add-btn.hide {
  opacity: 0;
  pointer-events: none;
  transform: translateX(-50%) scale(0.8);
  z-index: 99;
}

.add-btn::after {
  border: none;
}

.add-icon {
  font-size: 36rpx;
  color: #fff;
  font-weight: 300;
}

.add-text {
  font-size: 30rpx;
  color: #fff;
  font-weight: 600;
}

/* 模态框 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  z-index: 500;
}

.modal-mask.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 40rpx 40rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
  transform: translateY(100%);
  transition: transform 0.3s ease;
  z-index: 501;
  max-height: 90vh;
  display: flex;
  flex-direction: column;
}

.modal-content.show {
  transform: translateY(0);
}

/* 模态框头部 */
.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 40rpx 28rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #999;
  background: #f5f5f5;
  border-radius: 50%;
}

.modal-body {
  padding: 32rpx 40rpx 48rpx;
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

/* 表单项 */
.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: var(--theme-bg);
  border-radius: 20rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  color: #333;
  box-sizing: border-box;
}

.form-input::placeholder {
  color: #bbb;
}

/* 类型切换 - 左右对称 */
.type-toggle {
  display: flex;
  gap: 20rpx;
}

.type-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  background: var(--theme-bg);
  border-radius: 40rpx;
  color: #666;
  transition: all 0.3s ease;
}

.type-btn.active.expense {
  background: #FF6B6B;
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.35);
}

.type-btn.active.income {
  background: #2E7D32;
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.35);
}

/* 金额输入 */
.amount-input-wrap {
  display: flex;
  align-items: center;
  background: var(--theme-bg);
  border-radius: 20rpx;
  padding: 0 28rpx;
  height: 88rpx;
}

.amount-prefix {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-right: 8rpx;
}

.amount-input {
  flex: 1;
  background: transparent;
  padding: 0;
  height: 100%;
  font-size: 36rpx;
}

/* 周期选择 - 4列网格对称 */
.frequency-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.freq-btn {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  background: var(--theme-bg);
  border-radius: 20rpx;
  color: #666;
  transition: all 0.3s ease;
}

.freq-btn:active {
  transform: scale(0.95);
}

.freq-btn.active {
  background: var(--theme-gradient);
  color: #fff;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx var(--theme-shadow);
}

/* 星期选择 - 7列对称 */
.weekday-selector {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
}

.weekday-btn {
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  background: var(--theme-bg);
  border-radius: 16rpx;
  color: #666;
  transition: all 0.3s ease;
}

.weekday-btn:active {
  transform: scale(0.95);
}

.weekday-btn.active {
  background: var(--theme-gradient);
  color: #fff;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx var(--theme-shadow);
}

/* 日期选择器 */
.date-pickers {
  display: flex;
  gap: 20rpx;
}

.picker-value {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 28rpx;
  font-size: 30rpx;
  background: var(--theme-bg);
  border-radius: 20rpx;
  color: #333;
  box-sizing: border-box;
}

/* 分类/账户选择器 */
.category-selector {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 28rpx;
  background: var(--theme-bg);
  border-radius: 20rpx;
}

.selected-category {
  font-size: 30rpx;
  color: #333;
}

.category-selector .arrow {
  font-size: 22rpx;
  color: #999;
}

/* 提醒 */
.reminder-item {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.form-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.reminder-time {
  display: flex;
  align-items: center;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  height: 96rpx;
  background: var(--theme-gradient);
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-top: 48rpx;
  box-shadow: 0 8rpx 30rpx var(--theme-shadow);
}

.submit-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* 选择器弹窗 */
.picker-modal {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 40rpx 40rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
  transform: translateY(100%);
  transition: transform 0.3s ease;
  z-index: 600;
  max-height: 75vh;
  display: flex;
  flex-direction: column;
}

.picker-modal.show {
  transform: translateY(0);
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 40rpx 28rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.picker-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.picker-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #999;
  background: #f5f5f5;
  border-radius: 50%;
}

.picker-list {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx 40rpx 40rpx;
  -webkit-overflow-scrolling: touch;
}

/* 选择项 - 左右对称 */
.picker-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  transition: all 0.2s ease;
}

.picker-item:last-child {
  border-bottom: none;
}

.picker-item:active {
  background: var(--theme-bg);
  margin: 0 -40rpx;
  padding: 28rpx 40rpx;
  border-radius: 16rpx;
}

.picker-item.active {
  background: var(--theme-bg);
  margin: 0 -40rpx;
  padding: 28rpx 40rpx;
  border-radius: 16rpx;
}

.picker-icon {
  font-size: 44rpx;
  margin-right: 24rpx;
}

.picker-name {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.picker-check {
  font-size: 36rpx;
  color: var(--theme-primary);
  font-weight: bold;
}
