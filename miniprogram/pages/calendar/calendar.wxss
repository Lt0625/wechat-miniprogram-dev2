.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #FFF8E7;
}

.calendar-header {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 179, 71, 0.1);
}

.month-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.nav-btn {
  width: 80rpx;
  height: 80rpx;
  background-color: #FFF8E7;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #FF9800;
  transition: all 0.3s ease;
}

.nav-btn:active {
  transform: scale(0.9);
  background-color: #FFE4B5;
}

.current-month {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.calendar-week {
  display: flex;
  background-color: #fff;
  border-radius: 20rpx 20rpx 0 0;
  padding: 20rpx 10rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 179, 71, 0.1);
}

.week-day {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #999;
  font-weight: 500;
}

.calendar-days {
  background-color: #fff;
  border-radius: 0 0 20rpx 20rpx;
  padding: 20rpx 10rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 179, 71, 0.1);
  display: flex;
  flex-wrap: wrap;
}

.day {
  flex: 1 0 14.28%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100rpx;
  margin: 5rpx 0;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.day.current {
  background-color: #FFF8E7;
}

.day.other {
  opacity: 0.4;
}

.day.selected {
  background: linear-gradient(135deg, #FFB347 0%, #FF9800 100%);
}

.day.selected .day-number {
  color: #fff;
}

.day.has-bills::after {
  content: '';
  width: 8rpx;
  height: 8rpx;
  background-color: #FF9800;
  border-radius: 50%;
  margin-top: 4rpx;
}

.day.selected.has-bills::after {
  background-color: #fff;
}

.day.future {
  opacity: 0.3;
  pointer-events: none;
}

.day.future .day-number {
  color: #ccc;
}

.day.future .day-amount {
  color: #ddd;
}

.day-number {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.day-amount {
  font-size: 20rpx;
  color: #FF9800;
  margin-top: 4rpx;
}

.day.selected .day-amount {
  color: rgba(255, 255, 255, 0.9);
}

.date-detail {
  background-color: #fff;
  border-radius: 20rpx;
  margin-top: 20rpx;
  overflow: hidden;
  max-height: 0;
  transition: max-height 0.3s ease;
}

.date-detail.expand {
  max-height: 800rpx;
}

.detail-header {
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-date {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.detail-summary {
  font-size: 28rpx;
  color: #666;
}

.detail-list {
  max-height: 500rpx;
  overflow-y: auto;
  padding: 0 20rpx;
}

.bill-card {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.bill-card:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.08);
}

.card-icon {
  width: 80rpx;
  height: 80rpx;
  background-color: #FFF8E7;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.card-icon text {
  font-size: 36rpx;
}

.card-content {
  flex: 1;
  min-width: 0;
}

.card-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.card-category {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 16rpx;
}

.card-amount {
  font-size: 32rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.card-amount.expense {
  color: #FF6B6B;
}

.card-amount.income {
  color: #4ECDC4;
}

.card-sub {
  display: flex;
  align-items: center;
  gap: 8rpx;
  overflow: hidden;
}

.card-time {
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
}

.card-notes {
  font-size: 24rpx;
  color: #bbb;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-account {
  font-size: 24rpx;
  color: #999;
  margin-left: auto;
  flex-shrink: 0;
}

.empty-detail {
  padding: 60rpx 30rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

.detail-actions {
  padding: 30rpx;
}

.add-bill-btn {
  width: 100%;
  background: linear-gradient(135deg, #FFB347 0%, #FF9800 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 50rpx;
  padding: 24rpx;
  border: none;
  box-shadow: 0 8rpx 30rpx rgba(255, 179, 71, 0.4);
}

.add-bill-btn::after {
  border: none;
}

.add-btn {
  position: fixed;
  bottom: 80rpx;
  right: 30rpx;
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFB347 0%, #FF9800 100%);
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 8rpx 30rpx rgba(255, 179, 71, 0.5);
}

.add-btn text {
  font-size: 60rpx;
  color: white;
  line-height: 1;
}