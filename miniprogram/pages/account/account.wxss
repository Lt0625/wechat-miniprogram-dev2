.container {
  padding: 30rpx;
  background-color: #FFF8E7;
  min-height: 100vh;
}

.account-summary {
  background: linear-gradient(135deg, #FFB347 0%, #FF9800 100%);
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(255, 179, 71, 0.3);
}

.total-assets {
  text-align: center;
  margin-bottom: 30rpx;
}

.total-assets .label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  display: block;
  margin-bottom: 10rpx;
}

.total-assets .amount {
  font-size: 56rpx;
  font-weight: bold;
  color: #fff;
  display: block;
}

.summary-tabs {
  display: flex;
  justify-content: space-around;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 10rpx;
}

.summary-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.summary-tab.active {
  background-color: rgba(255, 255, 255, 0.95);
  color: #FF9800;
  font-weight: 600;
}

.account-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.account-count {
  font-size: 26rpx;
  color: #999;
}

.sort-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #FFB347;
  padding: 10rpx 20rpx;
  background-color: #FFF8E7;
  border-radius: 20rpx;
}

.sort-menu {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  max-height: 0;
  transition: max-height 0.3s ease;
}

.sort-menu.show {
  max-height: 300rpx;
}

.sort-option {
  padding: 24rpx 30rpx;
  font-size: 28rpx;
  color: #666;
  border-bottom: 1rpx solid #f5f5f5;
}

.sort-option:last-child {
  border-bottom: none;
}

.sort-option.active {
  color: #FFB347;
  background-color: #FFF8E7;
  font-weight: 600;
}

.account-list {
  background-color: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(255, 179, 71, 0.1);
}

.account-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: background-color 0.2s ease;
}

.account-item:last-child {
  border-bottom: none;
}

.account-item:active {
  background-color: #FFF8E7;
}

.account-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.account-icon {
  width: 80rpx;
  height: 80rpx;
  background-color: #FFF8E7;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.account-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.account-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.account-balance {
  font-size: 32rpx;
  font-weight: 600;
}

.account-balance.positive {
  color: #FF9800;
}

.account-balance.negative {
  color: #e74c3c;
}

.account-arrow {
  font-size: 28rpx;
  color: #ccc;
}

.add-account-btn {
  margin-top: 40rpx;
  background: linear-gradient(135deg, #FFB347 0%, #FF9800 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  padding: 30rpx;
  border-radius: 50rpx;
  box-shadow: 0 8rpx 30rpx rgba(255, 179, 71, 0.4);
}

.add-account-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}