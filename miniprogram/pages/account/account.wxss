.container {
  padding: 30rpx;
  background-color: var(--theme-bg);
  min-height: 100vh;
}

/* 顶部资产卡片 */
.account-summary {
  background: var(--theme-gradient);
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.15);
}

.total-assets {
  text-align: center;
  margin-bottom: 30rpx;
}

.total-assets .label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  display: block;
  margin-bottom: 10rpx;
}

.total-assets .amount {
  font-size: 56rpx;
  font-weight: bold;
  color: #fff;
  display: block;
}

.summary-tabs {
  display: flex;
  justify-content: space-around;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 10rpx;
}

.summary-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.summary-tab.active {
  background-color: rgba(255, 255, 255, 0.95);
  color: var(--theme-secondary);
  font-weight: 600;
}

/* 余额自动计算提示条 */
.balance-tip {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, #fff9e6 0%, #fff3cc 100%);
  border: 1rpx solid #ffe699;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
}

.tip-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.tip-icon {
  font-size: 28rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #b38f00;
}

.sync-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: var(--theme-gradient);
  color: #fff;
  font-size: 24rpx;
  padding: 12rpx 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 179, 71, 0.4);
}

.sync-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}

.sync-icon {
  font-size: 24rpx;
  font-weight: bold;
}

/* 账户区块 */
.account-section {
  margin-bottom: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.account-count {
  font-size: 26rpx;
  color: #999;
}

.sort-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: var(--theme-primary);
  padding: 10rpx 20rpx;
  background-color: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.sort-menu {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  max-height: 0;
  transition: max-height 0.3s ease;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.sort-menu.show {
  max-height: 300rpx;
}

.sort-option {
  padding: 24rpx 30rpx;
  font-size: 28rpx;
  color: #666;
  border-bottom: 1rpx solid #f5f5f5;
}

.sort-option:last-child {
  border-bottom: none;
}

.sort-option.active {
  color: var(--theme-primary);
  background-color: var(--theme-bg);
  font-weight: 600;
}

/* ========== 账户胶囊卡片网格 ========== */
.account-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.account-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  position: relative;
}

.account-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

/* 卡片顶部装饰条 */
.card-decoration {
  height: 6rpx;
  background: linear-gradient(90deg, var(--theme-primary) 0%, var(--theme-secondary) 100%);
}

.account-card.negative .card-decoration {
  background: linear-gradient(90deg, #e74c3c 0%, #ff6b6b 100%);
}

/* 卡片内容布局 */
.card-content {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
}

/* 左侧图标 */
.card-left {
  flex-shrink: 0;
  margin-right: 20rpx;
}

.account-icon {
  width: 72rpx;
  height: 72rpx;
  background: var(--theme-bg);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

/* 中间名称 */
.card-center {
  flex: 1;
  min-width: 0;
}

.account-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 右侧余额 */
.card-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.account-balance {
  display: flex;
  align-items: baseline;
  font-size: 32rpx;
  font-weight: 600;
}

.account-balance .balance-symbol {
  font-size: 24rpx;
  margin-right: 4rpx;
  color: #999;
}

.account-balance .balance-value {
  font-size: 32rpx;
}

.account-balance.positive {
  color: var(--theme-secondary);
}

.account-balance.negative {
  color: #e74c3c;
}

.card-arrow {
  font-size: 36rpx;
  color: #ccc;
  font-weight: 300;
}

/* 添加账户按钮 */
.add-account-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: var(--theme-gradient);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  padding: 30rpx;
  border-radius: 50rpx;
  box-shadow: 0 8rpx 30rpx rgba(255, 179, 71, 0.4);
  margin-top: 10rpx;
}

.add-account-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.btn-icon {
  font-size: 40rpx;
  font-weight: 300;
}

.btn-text {
  letter-spacing: 4rpx;
}

/* 底部安全区 */
.safe-bottom {
  height: calc(40rpx + env(safe-area-inset-bottom));
}
