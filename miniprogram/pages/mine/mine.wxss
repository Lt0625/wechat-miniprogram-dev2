.container {
  padding: 30rpx;
  min-height: 100vh;
  background-color: var(--theme-bg);
}

/* 用户信息卡片 */
.user-card {
  background: var(--theme-gradient);
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.15);
}

.user-card:active {
  opacity: 0.9;
}

.user-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  flex-shrink: 0;
}

.avatar image {
  width: 100%;
  height: 100%;
}

.avatar text {
  font-size: 52rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.nickname {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
}

.stats-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 4rpx;
}

.stat-item {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.stat-value {
  font-size: 26rpx;
  font-weight: bold;
  color: #fff;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stat-divider {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

.edit-icon {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.9);
  padding: 10rpx;
}

/* 主题区域 */
.theme-section {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.section-header {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.theme-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 16rpx;
}

.theme-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  border-radius: 16rpx;
  border: 4rpx solid transparent;
  transition: all 0.3s ease;
}

.theme-item:active {
  transform: scale(0.95);
}

.theme-item.active {
  border-color: var(--theme-primary);
  background-color: var(--theme-bg);
}

.theme-preview {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.12);
}

.theme-icon {
  font-size: 32rpx;
}

.theme-name {
  font-size: 20rpx;
  color: #333;
  font-weight: 500;
  text-align: center;
}

.theme-check {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 32rpx;
  height: 32rpx;
  background: var(--theme-primary);
  color: #fff;
  border-radius: 50%;
  font-size: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 菜单区域 */
.menu-section {
  margin-bottom: 30rpx;
}

.menu-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.menu-item {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.menu-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: var(--theme-gradient);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.menu-item:active {
  transform: scale(0.98);
  background-color: var(--theme-bg);
}

.menu-item:active::before {
  opacity: 1;
}

.menu-icon {
  width: 56rpx;
  height: 56rpx;
  background: var(--theme-bg);
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.menu-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.menu-arrow {
  font-size: 28rpx;
  color: #ccc;
  font-weight: bold;
}

/* 账本管理 - 横向布局 */
.book-manage-item {
  width: 100%;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  box-sizing: border-box;
}

.book-manage-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.book-manage-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.book-manage-item .menu-icon {
  width: 56rpx;
  height: 56rpx;
  background: var(--theme-bg);
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.book-manage-item .menu-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.book-manage-item .current-book-name {
  font-size: 26rpx;
  color: var(--theme-primary);
  font-weight: 500;
  max-width: 150rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.book-manage-item .menu-arrow {
  font-size: 28rpx;
  color: #ccc;
  font-weight: bold;
}

/* 版本信息 */
.version-info {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 30rpx;
}

.version-text {
  font-size: 24rpx;
  color: #bbb;
}

.version-dot {
  font-size: 24rpx;
  color: #ddd;
}
