.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: var(--theme-bg);
}

.user-info {
  background: var(--theme-gradient);
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.15);
}

.user-info:active {
  opacity: 0.9;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 30rpx;
  overflow: hidden;
}

.avatar image {
  width: 100%;
  height: 100%;
}

.avatar text {
  font-size: 60rpx;
}

.user-details {
  flex: 1;
}

.nickname {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.stats {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.edit-icon {
  font-size: 36rpx;
  margin-left: 20rpx;
}

.menu-list {
  background-color: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: background-color 0.2s ease;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: var(--theme-bg);
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 24rpx;
}

.menu-item text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-item .arrow {
  font-size: 28rpx;
  color: #ccc;
}

.version-info {
  text-align: center;
  padding: 30rpx;
  font-size: 24rpx;
  color: #999;
}

.theme-section {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.theme-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 12rpx;
}

.theme-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 8rpx;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.theme-item.active {
  border-color: var(--theme-primary);
  background-color: var(--theme-bg);
}

.theme-preview {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.theme-icon {
  font-size: 32rpx;
}

.theme-name {
  font-size: 18rpx;
  color: #333;
  font-weight: 500;
  text-align: center;
  line-height: 1.2;
}

.theme-check {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  font-size: 20rpx;
  color: var(--theme-primary);
  font-weight: bold;
}