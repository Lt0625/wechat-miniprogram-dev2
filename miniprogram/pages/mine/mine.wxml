<view class="container" data-theme="{{theme}}">
  <!-- 用户信息卡片 -->
  <view class="user-card" bindtap="editUserInfo">
    <view class="user-left">
      <view class="avatar">
        <image src="{{avatarUrl}}" mode="aspectFill" wx:if="{{avatarUrl}}" binderror="onAvatarError"></image>
        <text wx:else>👤</text>
      </view>
      <view class="user-info">
        <text class="nickname">{{nickname || '点击设置昵称'}}</text>
        <view class="stats-row">
          <view class="stat-item">
            <text class="stat-value">{{billCount || 0}}</text>
            <text class="stat-label">笔账单</text>
          </view>
          <view class="stat-divider">|</view>
          <view class="stat-item">
            <text class="stat-value">{{recordDays || 0}}</text>
            <text class="stat-label">天记账</text>
          </view>
        </view>
      </view>
    </view>
    <view class="edit-icon">✏️</view>
  </view>

  <!-- 主题皮肤 -->
  <view class="theme-section">
    <view class="section-header">
      <text class="section-title">🎨 主题皮肤</text>
    </view>
    <view class="theme-grid">
      <view
        class="theme-item {{currentTheme === item.key ? 'active' : ''}}"
        wx:for="{{themes}}"
        wx:key="key"
        bindtap="selectTheme"
        data-theme="{{item.key}}"
      >
        <view class="theme-preview" style="background: {{item.gradient}};">
          <text class="theme-icon">{{item.icon}}</text>
        </view>
        <text class="theme-name">{{item.name}}</text>
        <text class="theme-check" wx:if="{{currentTheme === item.key}}">✓</text>
      </view>
    </view>
  </view>

  <!-- 账本管理入口 -->
  <view class="menu-section">
    <view class="menu-item book-manage-item" bindtap="goToBookManage">
      <view class="book-manage-left">
        <view class="menu-icon">📒</view>
        <text class="menu-name">账本管理</text>
      </view>
      <view class="book-manage-right">
        <text class="current-book-name">{{currentBook.name}}</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 - 2列对称网格 -->
  <view class="menu-section">
    <view class="menu-grid">
      <!-- 第一行 -->
      <view class="menu-item" bindtap="goToCategoryManage">
        <view class="menu-icon">📂</view>
        <text class="menu-name">分类管理</text>
        <text class="menu-arrow">›</text>
      </view>
      
      <view class="menu-item" bindtap="goToRecurring">
        <view class="menu-icon">📅</view>
        <text class="menu-name">周期账单</text>
        <text class="menu-arrow">›</text>
      </view>
      
      <!-- 第二行 -->
      <view class="menu-item" bindtap="backupData">
        <view class="menu-icon">💾</view>
        <text class="menu-name">数据备份</text>
        <text class="menu-arrow">›</text>
      </view>
      
      <view class="menu-item" bindtap="restoreData">
        <view class="menu-icon">📥</view>
        <text class="menu-name">数据恢复</text>
        <text class="menu-arrow">›</text>
      </view>
      
      <!-- 第三行 -->
      <view class="menu-item" bindtap="clearData">
        <view class="menu-icon">🗑️</view>
        <text class="menu-name">清空数据</text>
        <text class="menu-arrow">›</text>
      </view>
      
      <view class="menu-item" bindtap="showAbout">
        <view class="menu-icon">ℹ️</view>
        <text class="menu-name">关于</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text class="version-text">版本 {{version}}</text>
    <text class="version-dot">•</text>
    <text class="version-text">桔记</text>
  </view>
</view>
