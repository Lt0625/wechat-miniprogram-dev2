<view class="container" data-theme="{{theme}}">
  <view class="form-section">
    <view class="form-item">
      <view class="label">账户名称</view>
      <input 
        class="form-input" 
        placeholder="请输入账户名称" 
        value="{{accountName}}" 
        bindinput="onAccountNameInput"
        maxlength="20"
      />
    </view>

    <view class="form-item">
      <view class="label">账户图标</view>
      <view class="icon-grid">
        <view 
          class="icon-option {{selectedIcon === item.icon ? 'active' : ''}}"
          wx:for="{{availableIcons}}"
          wx:key="icon"
          bindtap="selectIcon"
          data-icon="{{item.icon}}"
        >
          {{item.icon}}
        </view>
      </view>
    </view>

    <!-- 编辑模式：余额可手动调整 -->
    <view class="balance-auto-section" wx:if="{{isEdit}}">
      <view class="balance-info">
        <view class="balance-label">
          <text class="balance-icon">💰</text>
          <text>当前余额</text>
        </view>
        <view class="balance-value {{initialBalance >= 0 ? 'positive' : 'negative'}}">
          ¥{{initialBalance >= 0 ? initialBalance : -initialBalance}}
        </view>
      </view>
      <view class="balance-edit-row">
        <input 
          class="balance-input" 
          type="digit" 
          placeholder="手动调整余额"
          value="{{initialBalance}}"
          bindinput="onBalanceInput"
        />
        <text class="reset-btn" bindtap="resetBalanceToCalculated">↻ 恢复计算值</text>
      </view>
    </view>

    <!-- 新增模式：可设置初始余额 -->
    <view class="form-item" wx:if="{{!isEdit}}">
      <view class="label">初始余额</view>
      <input 
        class="form-input" 
        type="digit" 
        placeholder="0.00" 
        value="{{initialBalance}}" 
        bindinput="onBalanceInput"
      />
    </view>
  </view>

  <view class="action-section">
    <button class="save-btn" bindtap="saveAccount">{{isEdit ? '保存修改' : '添加账户'}}</button>
    <button class="delete-btn" wx:if="{{isEdit}}" bindtap="deleteAccount">删除账户</button>
  </view>
</view>