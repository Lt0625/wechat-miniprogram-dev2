.container {
  padding: 30rpx;
  background-color: var(--theme-bg);
  min-height: 100vh;
}

.form-section {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.form-item {
  margin-bottom: 40rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background-color: var(--theme-bg);
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #333;
  box-sizing: border-box;
}

.form-input:focus {
  border: 2rpx solid var(--theme-primary);
}

/* 余额自动计算区域 */
.balance-auto-section {
  margin-bottom: 40rpx;
  background: var(--theme-bg);
  border: 1rpx solid var(--theme-border);
  border-radius: 16rpx;
  padding: 24rpx;
}

.balance-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.balance-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

.balance-icon {
  font-size: 32rpx;
}

.balance-value {
  font-size: 40rpx;
  font-weight: bold;
}

.balance-value.positive {
  color: var(--theme-secondary);
}

.balance-value.negative {
  color: #e74c3c;
}

.balance-tip {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--theme-border);
}

.balance-edit-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--theme-border);
  gap: 16rpx;
}

.balance-input {
  flex: 1;
  height: 72rpx;
  padding: 0 20rpx;
  background-color: #fff;
  border: 2rpx solid var(--theme-border);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
}

.tip-text {
  font-size: 24rpx;
  color: var(--theme-text-muted);
}

.reset-btn {
  font-size: 24rpx;
  color: var(--theme-primary);
  font-weight: 600;
  padding: 8rpx 16rpx;
  background: rgba(0, 0, 0, 0.05);
  border-radius: 16rpx;
}

.reset-btn:active {
  opacity: 0.7;
}

.icon-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.icon-option {
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--theme-bg);
  border-radius: 16rpx;
  font-size: 50rpx;
  cursor: pointer;
  transition: all 0.3s ease;
  border: 4rpx solid transparent;
}

.icon-option.active {
  background-color: var(--theme-border);
  border-color: var(--theme-primary);
  transform: scale(1.1);
}

.action-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.save-btn {
  width: 100%;
  height: 96rpx;
  background: var(--theme-gradient);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.save-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.delete-btn {
  width: 100%;
  height: 96rpx;
  background-color: #fff;
  color: #e74c3c;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #e74c3c;
}

.delete-btn:active {
  background-color: #fef2f2;
}