/* 全局 Loading 组件样式 */

/* 容器 */
.loading-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.2s, visibility 0.2s;
}

.loading-container.show {
  opacity: 1;
  visibility: visible;
}

.loading-container.has-mask .mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

/* 遮罩层 */
.mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

/* 加载内容 */
.loading-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 60rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
}

/* 动画图标容器 */
.loading-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 24rpx;
}

/* 旋转圆点 */
.spinner {
  width: 16rpx;
  height: 16rpx;
  margin: 0 4rpx;
  background: #FFB347;
  border-radius: 50%;
  animation: pulse 1.2s ease-in-out infinite;
}

.spinner.delay-1 {
  animation-delay: 0.2s;
}

.spinner.delay-2 {
  animation-delay: 0.4s;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(0.8);
    opacity: 0.5;
  }
  50% {
    transform: scale(1.2);
    opacity: 1;
  }
}

/* 提示文字 */
.loading-title {
  font-size: 28rpx;
  color: #333;
  text-align: center;
}
